@model IEnumerable<F1_Fantasy_liga.Models.Driver>

<h1>Drivers</h1>

<div class="card-grid">
    @foreach (var item in Model)
    {
        var teamClass = item.Constructor?.Name switch
        {
            "Red Bull Racing" => "team-redbull",
            "Scuderia Ferrari" => "team-ferrari",
            "Mercedes-AMG Petronas" => "team-mercedes",
            _ => string.Empty
        };

        <div class="custom-card clickable-card accent-card @teamClass row-link" data-href="@Url.Action("Details", new { id = item.Id })" tabindex="0" role="link">
            <h3 class="card-title">@item.Name @item.Surname</h3>
            <div class="card-body">
                <div class="card-info-row">
                    <span class="card-info-label">Id</span>
                    <span class="card-info-value">@item.Id</span>
                </div>
                <div class="card-info-row">
                    <span class="card-info-label">Number</span>
                    <span class="card-info-value">@item.Number</span>
                </div>
                <div class="card-info-row">
                    <span class="card-info-label">Points</span>
                    <span class="card-info-value">@item.Points</span>
                </div>
                <div class="card-info-row">
                    <span class="card-info-label">Constructor</span>
                    <span class="card-info-value">@item.Constructor?.Name</span>
                </div>
            </div>
            <div class="card-actions">
                <a class="details-btn" asp-action="Details" asp-route-id="@item.Id">Details</a>
            </div>
        </div>
    }
</div>