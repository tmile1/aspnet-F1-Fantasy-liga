<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - F1_Fantasy_liga</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/F1_Fantasy_liga.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty);
    }
    <header>
        <nav class="top-nav">
            <div class="page-shell nav-shell">
                <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">F1 Fantasy Liga</a>
                <ul class="nav-links">
                    <li><a class="nav-link @(currentController == "BuildTeam" ? "active" : string.Empty)" asp-controller="BuildTeam" asp-action="Index">Build Team</a></li>
                    <li><a class="nav-link @(currentController == "Drivers" ? "active" : string.Empty)" asp-controller="Drivers" asp-action="Index">Drivers</a></li>
                    <li><a class="nav-link @(currentController == "Constructors" ? "active" : string.Empty)" asp-controller="Constructors" asp-action="Index">Constructors</a></li>
                    <li><a class="nav-link @(currentController == "Circuits" ? "active" : string.Empty)" asp-controller="Circuits" asp-action="Index">Circuits</a></li>
                    <li><a class="nav-link @(currentController == "Races" ? "active" : string.Empty)" asp-controller="Races" asp-action="Index">Races</a></li>
                    <li><a class="nav-link @(currentController == "RaceResults" ? "active" : string.Empty)" asp-controller="RaceResults" asp-action="Index">Race Results</a></li>
                    <li><a class="nav-link @(currentController == "Users" ? "active" : string.Empty)" asp-controller="Users" asp-action="Index">Users</a></li>
                    <li><a class="nav-link @(currentController == "FantasyLeagues" ? "active" : string.Empty)" asp-controller="FantasyLeagues" asp-action="Index">Fantasy Leagues</a></li>
                    <li><a class="nav-link @(currentController == "FantasyTeams" ? "active" : string.Empty)" asp-controller="FantasyTeams" asp-action="Index">Fantasy Teams</a></li>
                </ul>
            </div>
        </nav>
    </header>
    <div class="page-shell">
        <main role="main" class="content-wrap">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="page-shell">
            &copy; 2026 - F1_Fantasy_liga - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
