@model IEnumerable<F1_Fantasy_liga.Models.FantasyTeam>

<h1>Fantasy Teams</h1>

<div class="card-grid">
    @foreach (var item in Model)
    {
        <div class="custom-card clickable-card row-link" data-href="@Url.Action("Details", new { id = item.Id })" tabindex="0" role="link">
            <h3 class="card-title">@item.Name</h3>
            <div class="card-body">
                <div class="card-info-row">
                    <span class="card-info-label">Id</span>
                    <span class="card-info-value">@item.Id</span>
                </div>
                <div class="card-info-row">
                    <span class="card-info-label">User</span>
                    <span class="card-info-value">@item.User?.Name @item.User?.Surname</span>
                </div>
                <div class="card-info-row">
                    <span class="card-info-label">League</span>
                    <span class="card-info-value">@item.FantasyLeague?.Name</span>
                </div>
                <div class="card-info-row">
                    <span class="card-info-label">Points</span>
                    <span class="card-info-value">@item.Points</span>
                </div>
            </div>
        </div>
    }
</div>