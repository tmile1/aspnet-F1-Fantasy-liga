@model IEnumerable<F1_Fantasy_liga.Models.RaceResult>

<h1>Race Results</h1>

<table border="1" cellpadding="6" cellspacing="0">
    <thead>
        <tr>
            <th>Id</th>
            <th>Race</th>
            <th>Driver</th>
            <th>Position</th>
            <th>Points</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr class="row-link" data-href="@Url.Action("Details", new { id = item.Id })" tabindex="0" role="link">
            <td>@item.Id</td>
            <td>@item.Race?.Name</td>
            <td>@item.Driver?.Name @item.Driver?.Surname</td>
            <td>@item.FinishedPosition</td>
            <td>@item.ScoredPoints</td>
            <td><a class="details-btn" asp-action="Details" asp-route-id="@item.Id">Details</a></td>
        </tr>
    }
    </tbody>
</table>