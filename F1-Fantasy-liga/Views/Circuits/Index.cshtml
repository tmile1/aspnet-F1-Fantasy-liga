@model IEnumerable<F1_Fantasy_liga.Models.Circuit>

<h1>Circuits</h1>

<div class="card-grid">
    @foreach (var item in Model)
    {
        <div class="custom-card clickable-card row-link" data-href="@Url.Action("Details", new { id = item.Id })" tabindex="0" role="link">
            <h3 class="card-title">@item.Name</h3>
            <div class="card-body">
                <div class="card-info-row">
                    <span class="card-info-label">Id</span>
                    <span class="card-info-value">@item.Id</span>
                </div>
                <div class="card-info-row">
                    <span class="card-info-label">Country</span>
                    <span class="card-info-value">@item.Country</span>
                </div>
                <div class="card-info-row">
                    <span class="card-info-label">City</span>
                    <span class="card-info-value">@item.City</span>
                </div>
            </div>
            <div class="card-actions">
                <a class="details-btn" asp-action="Details" asp-route-id="@item.Id">Details</a>
            </div>
        </div>
    }
</div>